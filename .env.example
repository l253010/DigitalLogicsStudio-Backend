PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
MONGO_URI=mongodb://localhost:27017/digital-logics-studio
JWT_SECRET=your
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_DAYS=7

# Gmail account used to send password-reset OTP emails.
# GMAIL_APP_PASSWORD must be a 16-character Google App Password
# (Google Account > Security > 2-Step Verification > App passwords),
# not the account's normal login password.
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
